    "@nuxt/ui": "^4.4.0",
    "@types/node": "^25.0.3",
    "axios": "^1.7.9",
    "nuxt": "^4.2.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.10.0",
    "eslint": "^9.39.1",
    "openapi-typescript-codegen": "^0.25.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "overrides": {
      "@nuxt/kit": "4.2.2",
